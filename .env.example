# SQLite database path (relative to project root in dev, /app/data in Docker)
DATABASE_URL="file:./data/app.db"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# Token expiry (e.g. 7d, 30d)
JWT_EXPIRES_IN="30d"


# Optional: seed user (used by prisma/seed.ts)
SEED_EMAIL="me@example.com"
SEED_PASSWORD="your-secure-password"
SEED_DISPLAY_NAME="Me"
